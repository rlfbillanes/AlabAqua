<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AlabAqua</title>

    <link rel="icon" type="image/x-icon" href="~/favicon.ico" />

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/AlabAqua.Web.styles.css" asp-append-version="true" />

    <style>
        /* NAVBAR */
        .navbar-custom {
            position: fixed;
            top: 0;
            width: 100%;
            padding: 1rem 2rem;
            z-index: 1000;
            background: transparent !important;
            transition: background-color 0.3s ease, padding 0.3s ease;
        }

        .navbar-scrolled {
            background: rgba(0, 0, 0, 0.85) !important;
            padding: 0.6rem 2rem;
            backdrop-filter: blur(6px);
        }

        /* LOGO */
        .navbar-brand img {
            height: 44px;
            width: auto;
            display: block;
        }

        /* NAV LINKS */
        .navbar-custom .nav-link {
            color: #ffffff !important;
            font-weight: 500;
            font-size: 0.95rem;
            letter-spacing: 0.03em;
            margin-left: 1.2rem;
            transition: color 0.2s ease;
        }

            .navbar-custom .nav-link:hover {
                color: #60a5fa !important;
            }

        .navbar-toggler {
            border: none;
        }

        .navbar-toggler-icon {
            filter: brightness(0) invert(1);
        }

        /* MAIN CONTENT — hero must start at top */
        main {
            margin-top: 0;
        }

        /* FOOTER */
        footer {
            background: #111827;
            color: #9ca3af;
            padding: 1.5rem 0;
            text-align: center;
        }

            footer a {
                color: #60a5fa;
                text-decoration: none;
            }

                footer a:hover {
                    text-decoration: underline;
                }
    </style>
</head>

<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark navbar-custom">
            <div class="container-fluid">

                <!-- LOGO -->
                <a class="navbar-brand d-flex align-items-center" asp-area="" asp-controller="Home" asp-action="Index">
                    <img src="~/alabaqua-logo.png" alt="AlabAqua Logo" />
                </a>

                <!-- MOBILE TOGGLER -->
                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <!-- NAV LINKS -->
                <div class="collapse navbar-collapse justify-content-end" id="mainNav">
                    <ul class="navbar-nav">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Home" asp-action="Index">Home</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#community">Community</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" href="#species">Species</a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-area="Admin" asp-controller="Dashboard" asp-action="Index">Admin</a>
                        </li>
                    </ul>
                </div>

            </div>
        </nav>
    </header>

    <!-- FULL-WIDTH CONTENT -->
    <main role="main" class="pb-3">
        @RenderBody()
    </main>

    <footer>
        <div class="container">
            &copy; 2026 - AlabAqua | <a asp-controller="Home" asp-action="Privacy">Privacy Policy</a>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script>
        // Navbar scroll effect
        window.addEventListener("scroll", function () {
            const navbar = document.querySelector(".navbar-custom");
            if (window.scrollY > 50) {
                navbar.classList.add("navbar-scrolled");
            } else {
                navbar.classList.remove("navbar-scrolled");
            }
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>

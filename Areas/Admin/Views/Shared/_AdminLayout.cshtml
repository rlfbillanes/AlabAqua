@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@ViewData["Title"] - Admin Panel</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    <style>
        body {
            display: flex;
            min-height: 100vh;
        }

        .sidebar {
            width: 250px;
            background: #1f2937;
            color: white;
            padding: 20px 0;
        }

        .sidebar a {
            color: #d1d5db;
            padding: 12px 20px;
            display: block;
            text-decoration: none;
        }

        .sidebar a:hover {
            background: #374151;
            color: white;
        }

        .content {
            flex: 1;
            padding: 20px;
            background: #f3f4f6;
        }

        .topbar {
            background: white;
            padding: 15px 20px;
            border-bottom: 1px solid #e5e7eb;
            margin-bottom: 20px;
        }
    </style>
</head>

<body>

    <!-- SIDEBAR -->
    <div class="sidebar">
        <h4 class="text-center mb-4">Admin Panel</h4>

        <a href="/Admin/Dashboard">Dashboard</a>
        <a href="/Admin/Species">Species</a>
        <a href="/Admin/Users">Users</a>
        <a href="/Admin/Tanks">Tanks</a>
        <a href="/Admin/Settings">Settings</a>
    </div>

    <!-- MAIN CONTENT -->
    <div class="content">
        <div class="topbar">
            <h5 class="m-0">@ViewData["Title"]</h5>
        </div>

        @RenderBody()
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
